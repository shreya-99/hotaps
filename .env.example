# ================================================================
# .env.example — Copy this to .env and fill in your real values
# ================================================================
# IMPORTANT: NEVER commit your actual .env file to git!
#            It's already in .gitignore.
# ================================================================

# ── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,https://hotaps.com

# ── Contact Info ─────────────────────────────────────────────────
# WhatsApp number WITH country code, NO spaces or dashes
# India example: 91 + 9876543210 = 919876543210
WHATSAPP_NUMBER=919876543210

# Display-formatted phone number shown in the UI
PHONE_NUMBER=+91 98765 43210

# ── Email (SMTP) ─────────────────────────────────────────────────
# For Gmail: use an App Password (not your login password)
# https://myaccount.google.com/apppasswords
#
# For SendGrid SMTP:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=SG.your_sendgrid_api_key_here
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password_here

# Email FROM name/address (shown in inbox)
EMAIL_FROM="HoTaps Website" <no-reply@hotaps.com>

# Email TO — where contact form leads are sent (your business email)
EMAIL_TO=hello@hotaps.com
